<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Moses Odhiambo's Portfolio</title>

    <style>
        /* RESET */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            background: #0f172a;
            color: #fff;
            line-height: 1.6;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        /* NAVBAR */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 10%;
            background: #020617;
        }

        nav a {
            margin-left: 20px;
            color: #cbd5f5;
            transition: 0.3s;
        }

        nav a:hover {
            color: #3b82f6;
        }

        /* HERO SECTION */
        .hero {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 60px 10%;
            flex-wrap: wrap;
        }

        .hero-text {
            max-width: 500px;
        }

        .hero-text h1 {
            font-size: 2.5rem;
        }

        .highlight {
            color: #3b82f6;
        }

        .hero-text p {
            margin: 20px 0;
            color: #cbd5f5;
        }

        .btn {
            display: inline-block;
            padding: 10px 20px;
            background: #3b82f6;
            color: #fff;
            border-radius: 5px;
            transition: 0.3s;
        }

        .btn:hover {
            background: #2563eb;
        }

        /* PROFILE IMAGE */
        .hero-img img {
            width: 280px;
            border-radius: 50%;
            box-shadow: 0 0 40px rgba(59,130,246,0.5);
        }

        /* SECTIONS */
        section {
            padding: 60px 10%;
        }

        h2 {
            margin-bottom: 20px;
            color: #3b82f6;
        }

        .projects, .skills {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }

        .card {
            background: #020617;
            padding: 20px;
            border-radius: 10px;
            transition: 0.3s;
        }

        .card:hover {
            transform: translateY(-5px);
        }

        /* CONTACT */
        form input, form textarea {
            width: 100%;
            padding: 10px;
            margin-bottom: 10px;
            border: none;
            border-radius: 5px;
        }

        form button {
            padding: 10px 20px;
            background: #3b82f6;
            border: none;
            color: #fff;
            border-radius: 5px;
        }

        /* FOOTER */
        footer {
            text-align: center;
            padding: 20px;
            background: #020617;
            margin-top: 20px;
        }

        /* RESPONSIVE */
        @media(max-width: 768px) {
            .hero {
                flex-direction: column;
                text-align: center;
            }

            .hero-img {
                margin-top: 20px;
            }
        }
    </style>
</head>
<body>

    <!-- HEADER -->
    <header>
        <h2>MosesPortfolio</h2>
        <nav>
            <a href="#">Home</a>
            <a href="#about">About</a>
            <a href="#projects">Projects</a>
            <a href="#skills">Skills</a>
            <a href="#contact">Contact</a>
        </nav>
    </header>

    <!-- HERO -->
    <section class="hero">
        <div class="hero-text">
            <h1>Hi, I'm <br> <span class="highlight">Moses Odhiambo</span></h1>
            <p>
                I craft clean, modern, and slightly addictive web experiences.  
                Turning coffee ☕ into code and ideas into reality — one pixel at a time.
            </p>
            <a href="#projects" class="btn">View My Work</a>
        </div>

        <div class="hero-img">
            <img src="Downloads/student.jfif" alt="Profile Image">
        </div>
    </section>

    <!-- ABOUT -->
    <section id="about">
        <h2>About Me</h2>
        <p>
            I'm Moses Odhiambo, a passionate web developer studying at MTTI. I live in Lucky Summer and enjoy building sleek and functional websites.  
            I love solving problems, learning new technologies, and adding a little flair to everything I create.
        </p>
    </section>

    <!-- PROJECTS -->
    <section id="projects">
        <h2>Projects</h2>
        <div class="projects">
            <div class="card">
                <h3>Project One</h3>
                <p>A cool web app with modern UI.</p>
                <small>HTML, CSS, JS</small>
            </div>

            <div class="card">
                <h3>Project Two</h3>
                <p>Responsive portfolio design.</p>
                <small>HTML, CSS</small>
            </div>

            <div class="card">
                <h3>Project Three</h3>
                <p>Interactive landing page.</p>
                <small>JavaScript</small>
            </div>
        </div>
    </section>

    <!-- SKILLS -->
    <section id="skills">
        <h2>Skills</h2>
        <div class="skills">
            <div class="card">HTML</div>
            <div class="card">CSS</div>
            <div class="card">JavaScript</div>
            <div class="card">Python</div>
            <div class="card">Responsive Design</div>
        </div>
    </section>

    <!-- CONTACT -->
    <section id="contact">
        <h2>Contact Me</h2>
        <form id="contactForm">
            <input type="text" placeholder="Your Name">
            <input type="email" placeholder="Your Email">
            <textarea rows="5" placeholder="Your Message"></textarea>
            <button type="submit">Send Message</button>
        </form>
    </section>

    <!-- FOOTER -->
    <footer>
        <p>© 2026 My Portfolio | Built with passion 💻</p>
    </footer>

    <script>
        const form = document.getElementById('contactForm');
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            alert('Thank you for your message! I will get back to you soon.');
        });
    </script>

</body>
</html>